# Omgeving- en configuratiebestanden (OM JE API KEYS TE BESCHERMEN)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Zorg ervoor dat je .env.example wél kunt pushen (zonder geheimen)
